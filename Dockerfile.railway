FROM ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies + PHP + Nginx
RUN apt-get update && apt-get install -y \
    php7.4-fpm \
    php7.4-mysql \
    php7.4-zip \
    php7.4-gd \
    php7.4-xml \
    php7.4-bcmath \
    php7.4-mbstring \
    php7.4-curl \
    nginx \
    curl \
    unzip \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

WORKDIR /var/www

COPY . /var/www

# Install PHP dependencies
RUN composer install --no-dev --optimize-autoloader --no-interaction

# Set permissions
RUN chown -R www-data:www-data /var/www \
    && chmod -R 755 /var/www/storage \
    && chmod -R 755 /var/www/bootstrap/cache

# Copy Nginx config
COPY docker/nginx/railway.conf /etc/nginx/sites-available/default
RUN rm -f /etc/nginx/sites-enabled/default \
    && ln -s /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

# Write startup script
RUN echo '#!/bin/bash' > /start.sh && \
    echo 'sed -i "s|listen = /run/php/php7.4-fpm.sock|listen = 127.0.0.1:9000|g" /etc/php/7.4/fpm/pool.d/www.conf' >> /start.sh && \
    echo '/usr/sbin/php-fpm7.4 -D' >> /start.sh && \
    echo 'sleep 1' >> /start.sh && \
    echo 'sed -i "s/listen 80/listen ${PORT:-80}/g" /etc/nginx/sites-available/default' >> /start.sh && \
    echo 'nginx &' >> /start.sh && \
    echo 'sleep 2' >> /start.sh && \
    echo 'echo "=== Nginx PID: $(pgrep nginx) ==="' >> /start.sh && \
    echo 'echo "=== Nginx running check ==="' >> /start.sh && \
    echo 'ps aux | grep nginx' >> /start.sh && \
    echo 'cd /var/www && php artisan migrate --force' >> /start.sh && \
    echo 'php artisan config:cache' >> /start.sh && \
    echo 'chown -R www-data:www-data /var/www/storage' >> /start.sh && \
    echo 'echo "=== All services started, keeping container alive ==="' >> /start.sh && \
    echo 'tail -f /var/log/nginx/error.log' >> /start.sh && \
    chmod +x /start.sh

EXPOSE 8080

CMD ["/start.sh"]